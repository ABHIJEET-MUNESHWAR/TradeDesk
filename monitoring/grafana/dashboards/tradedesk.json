{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "TradeDesk OMS",
  "uid": "tradedesk-oms",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Orders placed by status (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (status) (rate(tradedesk_orders_placed_total[5m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2,
      "title": "Pre-trade risk outcomes (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum by (outcome) (rate(tradedesk_risk_checks_total[5m]))", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 3,
      "title": "GraphQL requests by operation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (operation) (rate(tradedesk_graphql_requests_total[5m]))", "legendFormat": "{{operation}}" }
      ]
    },
    {
      "id": 4,
      "title": "PlaceOrder latency (p50/p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(tradedesk_place_order_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.99, sum(rate(tradedesk_place_order_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    }
  ]
}
